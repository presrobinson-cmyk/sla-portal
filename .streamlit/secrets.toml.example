# Copy this to secrets.toml and fill in real values
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key"

# Anthropic API key for AI chat (get from console.anthropic.com)
ANTHROPIC_API_KEY = "sk-ant-..."

# User accounts: username = "password_hash"
# Generate hashes with: python -c "import hashlib; print(hashlib.sha256(b'your_password').hexdigest())"
[users]
arnold_ventures = "hash_here"
vital_projects = "hash_here"
just_trust = "hash_here"
